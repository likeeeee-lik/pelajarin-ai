{
  "expo": {
    "name": "Pelajarin.ai",
    "slug": "pelajarin-ai",
    "scheme": "pelajarin",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B1120",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.pelajarin.app"
    },
    "android": {
      "package": "ai.pelajarin.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router", "expo-status-bar", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
