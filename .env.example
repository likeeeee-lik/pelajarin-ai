# ─── Web (apps/web) ─────────────────────────────────────────
# Mode auth: "local" (email+password) | "logto" | "stub" (UI-only)
# HARUS sama dengan AUTH_MODE di API.
NEXT_PUBLIC_AUTH_MODE=local
NEXT_PUBLIC_API_URL=http://localhost:4000

# Logto (isi saat tenant siap) — lihat docs/logto-setup.md
# LOGTO_ENDPOINT: URL tenant, mis. https://xxxx.logto.app/
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
# 32+ karakter acak: openssl rand -base64 32
LOGTO_COOKIE_SECRET=
LOGTO_BASE_URL=http://localhost:3000
# Identifier API resource di Logto (mis. https://api.pelajarin.ai)
LOGTO_API_RESOURCE=

# ─── API (apps/api) ─────────────────────────────────────────
API_PORT=4000
# Mode auth: "local" (email+password, JWT sendiri) | "logto" | "stub"
#   stub = terima token apa pun sebagai demo-user. HANYA dev; ditolak saat
#   NODE_ENV=production (guard gagal-tertutup → semua request 401).
AUTH_MODE=local
# Wajib saat AUTH_MODE=local. Min. 32 karakter acak:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_JWT_SECRET=
# Supabase Postgres (Prisma)
# DATABASE_URL = transaction pooler (port 6543) + ?pgbouncer=true (runtime app)
# DIRECT_URL   = direct/session (port 5432) untuk prisma migrate
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pelajarin?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/pelajarin?schema=public
# Verifikasi JWT dari Logto (turunan dari LOGTO_ENDPOINT)
#   LOGTO_JWKS_URL = {endpoint}/oidc/jwks
#   LOGTO_ISSUER   = {endpoint}/oidc
#   LOGTO_AUDIENCE = sama dengan LOGTO_API_RESOURCE
# Selama JWKS kosong, API berjalan mode stub (dev saja).
LOGTO_JWKS_URL=
LOGTO_ISSUER=
LOGTO_AUDIENCE=

# Identitas user (email/nama) TIDAK ada di access token, dan menyelipkannya lewat
# "Custom JWT" adalah fitur Pro berbayar. API mengambilnya dari Management API
# memakai aplikasi Machine-to-machine (1 gratis di paket Free Logto).
# Kosongkan = fitur mati, profil memakai email tiruan (aman, tak merusak apa pun).
LOGTO_ENDPOINT=
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
# opsional; default {LOGTO_ENDPOINT}/api
LOGTO_MANAGEMENT_API_RESOURCE=

# Supabase Storage (file asli). Isi SERVICE_KEY untuk mengaktifkan penyimpanan file.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=materials

# AI — provider: "mock" (default) atau "claude"
# Set AI_PROVIDER=claude + isi ANTHROPIC_API_KEY untuk AI nyata.
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Model khusus prediksi ujian (lebih kuat). Default Opus; ganti ke
# claude-sonnet-5 bila ingin lebih hemat.
ANTHROPIC_MODEL_PREDICT=claude-opus-4-8
GROQ_API_KEY=
