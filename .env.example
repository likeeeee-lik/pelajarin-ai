# ─── Web (apps/web) ─────────────────────────────────────────
# Mode auth: "stub" (UI-only, tanpa server) atau "logto"
NEXT_PUBLIC_AUTH_MODE=stub
NEXT_PUBLIC_API_URL=http://localhost:4000

# Logto (isi saat tenant siap)
LOGTO_ENDPOINT=https://auth.pelajarin.ai
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=
LOGTO_BASE_URL=http://localhost:3000

# ─── API (apps/api) ─────────────────────────────────────────
API_PORT=4000
# Supabase Postgres (Prisma)
# DATABASE_URL = transaction pooler (port 6543) + ?pgbouncer=true (runtime app)
# DIRECT_URL   = direct/session (port 5432) untuk prisma migrate
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pelajarin?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/pelajarin?schema=public
# Verifikasi JWT dari Logto
LOGTO_JWKS_URL=https://auth.pelajarin.ai/oidc/jwks
LOGTO_ISSUER=https://auth.pelajarin.ai/oidc
LOGTO_AUDIENCE=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# AI (isi nanti)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
